# 서버
PORT=4000
DATABASE_URL="file:./dev.db"

# 실제 키가 발급되기 전까지는 mock 모드로 동작한다.
# TOSS_MODE=mock  -> 실제 API 호출 대신 로컬 mock 응답 사용
# TOSS_MODE=live  -> 아래 실제 키를 사용해 토스페이먼츠/토스플레이스 API 호출
TOSS_MODE=mock

# 토스페이먼츠 (LinkPay, 빌링) - live 모드에서만 필요
TOSSPAYMENTS_SECRET_KEY=

# 토스플레이스 Open API (POS 플러그인) - live 모드에서만 필요
TOSSPLACE_ACCESS_KEY=
TOSSPLACE_SECRET_KEY=
TOSSPLACE_MERCHANT_ID=

# 웹훅 검증용 (live 모드에서 실제 발급되는 값으로 교체)
TOSS_WEBHOOK_SECRET=
