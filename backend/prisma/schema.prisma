generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StudentStatus {
  ACTIVE
  PAUSED
  WITHDRAWN
}

model Student {
  id            String        @id @default(cuid())
  name          String
  guardianPhone String
  courseName    String
  monthlyFee    Int
  status        StudentStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  billingKey      BillingKey?
  billingSchedule BillingSchedule?
  paymentLinks    PaymentLink[]
  paymentHistory  PaymentHistory[]
}

enum BillingKeyStatus {
  PENDING
  ACTIVE
  FAILED_REGISTRATION
  REVOKED
}

model BillingKey {
  id          String           @id @default(cuid())
  studentId   String           @unique
  student     Student          @relation(fields: [studentId], references: [id])
  customerKey String           @unique
  billingKey  String?
  cardLast4   String?
  status      BillingKeyStatus @default(PENDING)
  issuedAt    DateTime?
  createdAt   DateTime         @default(now())
}

enum PaymentLinkStatus {
  WAITING
  PAID
  EXPIRED
  CANCELED
}

model PaymentLink {
  id         String            @id @default(cuid())
  studentId  String
  student    Student           @relation(fields: [studentId], references: [id])
  productKey String            @unique
  url        String
  amount     Int
  reason     String
  status     PaymentLinkStatus @default(WAITING)
  sentAt     DateTime          @default(now())
  paidAt     DateTime?
}

enum PaymentType {
  LINKPAY
  BILLING
}

enum PaymentStatus {
  SUCCESS
  FAILED
}

model PaymentHistory {
  id         String        @id @default(cuid())
  studentId  String
  student    Student       @relation(fields: [studentId], references: [id])
  type       PaymentType
  amount     Int
  status     PaymentStatus
  failReason String?
  paidAt     DateTime      @default(now())
}

model BillingSchedule {
  id         String   @id @default(cuid())
  studentId  String   @unique
  student    Student  @relation(fields: [studentId], references: [id])
  dueDay     Int
  nextRunAt  DateTime
  retryCount Int      @default(0)
  active     Boolean  @default(true)
}
