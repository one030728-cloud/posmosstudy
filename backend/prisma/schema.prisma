generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StudentStatus {
  ACTIVE
  PAUSED
  WITHDRAWN
}

model Student {
  id            String        @id @default(cuid())
  name          String
  guardianPhone String
  courseName    String
  monthlyFee    Int
  status        StudentStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  paymentLinks   PaymentLink[]
  paymentHistory PaymentHistory[]
}

enum PaymentLinkStatus {
  WAITING
  PAID
  EXPIRED
  CANCELED
}

model PaymentLink {
  id         String            @id @default(cuid())
  studentId  String
  student    Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  productKey String            @unique
  url        String
  amount     Int
  reason     String
  status     PaymentLinkStatus @default(WAITING)
  sentAt     DateTime          @default(now())
  paidAt     DateTime?
}

enum PaymentStatus {
  SUCCESS
  FAILED
}

model PaymentHistory {
  id         String        @id @default(cuid())
  studentId  String
  student    Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount     Int
  status     PaymentStatus
  failReason String?
  paidAt     DateTime      @default(now())
}

enum BulkLinkStatus {
  PENDING
  SENT
  FAILED
}

// 일괄 결제링크 발송 (즉시 또는 예약). scheduledAt이 현재보다 미래면
// 스케줄러가 그 시각에 studentIds 각각에 대해 결제링크를 발송한다.
model ScheduledBulkLink {
  id          String         @id @default(cuid())
  studentIds  String[]
  amount      Int
  reason      String
  scheduledAt DateTime
  status      BulkLinkStatus @default(PENDING)
  createdAt   DateTime       @default(now())
}
